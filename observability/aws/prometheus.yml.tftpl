global:
  scrape_interval: 15s

scrape_configs:
  - job_name: expense-control-back
    metrics_path: /api/metrics
    dns_sd_configs:
      - names: ["${backend_host}"]
        type: A
        port: ${backend_port}

  - job_name: expense-control-otel-collector
    static_configs:
      - targets: ["${otel_collector_host}:${otel_metrics_port}"]
